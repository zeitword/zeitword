# DB (Default value for local postgres setup)
NUXT_DSN="postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable"
NUXT_SESSION_PASSWORD=""

# AWS S3
NUXT_S3_ACCESS_KEY_ID="any"
NUXT_S3_SECRET_ACCESS_KEY="any"
NUXT_S3_ENDPOINT="http://localhost:8333"
NUXT_S3_BUCKET="zeitword"
NUXT_S3_REGION="eu-central-1"
## curl -X PUT http://localhost:8333/zeitword || true


# Waitlist
NUXT_RESEND=""
NUXT_PUBLIC_SITE_URL=""
